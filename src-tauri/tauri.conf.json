{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slick's Salvage",
  "version": "0.1.0",
  "identifier": "com.brett.slicksalvage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Slick's Salvage & Mining Operation Training Module",
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Slick's Salvage arcade run.",
    "longDescription": "Neon-pixel arcade salvage and mining. Extract before the gate closes."
  }
}
